edda.subcult.tv {
	@api path /api/* /api/v1/campaigns/*/ws

	handle @api {
		header {
			Cache-Control "no-store, no-cache, must-revalidate, max-age=0, s-maxage=0"
			Pragma "no-cache"
			Expires "0"
			Surrogate-Control "no-store"
		}

		reverse_proxy edda-api:8080
	}

	handle {
		reverse_proxy edda-web:80
	}
}
