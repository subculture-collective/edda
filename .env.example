# Database
EDDA_DB_URL=postgres://edda:edda@localhost:5432/edda?sslmode=disable

# LLM Provider (ollama or claude)
EDDA_LLM_PROVIDER=ollama

# Ollama (main LLM - desktop GPU)
EDDA_LLM_OLLAMA_ENDPOINT=http://10.0.0.10:11434
EDDA_LLM_OLLAMA_MODEL=qwen3:14b
EDDA_LLM_OLLAMA_TIMEOUTSECONDS=180

# Ollama (embedding - local server)
EDDA_LLM_OLLAMA_EMBEDDINGENDPOINT=http://ollama:11434
EDDA_LLM_OLLAMA_EMBEDDINGMODEL=nomic-embed-text

# Claude (required if EDDA_LLM_PROVIDER=claude)
# API key precedence (highest to lowest): EDDA_LLM_CLAUDE_APIKEY > ANTHROPIC_API_KEY
# EDDA_LLM_CLAUDE_APIKEY=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...
# EDDA_LLM_CLAUDE_MODEL=claude-sonnet-4-6

# Server
EDDA_SERVER_PORT=8080
