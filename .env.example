# ──────────────────────────────────────────────────────────────────────────────
# Edda / game-master — local development env contract
#
# This file is the canonical source of truth for configuration knobs.
# Copy to `.env`, adjust values, and run the app.
#
# Every variable here maps 1:1 to the koanf config tree in internal/config/config.go
# via the rule:  GM_<UPPER_SECTION>_<UPPER_KEY>  →  <section>.<key>
#
# For production overrides (release tag, container names, Caddy, Cloudflare),
# see `.env.production.example` — it documents only what differs from this file.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
GM_DB_URL=postgres://game_master:game_master@localhost:5432/game_master?sslmode=disable

# ─── LLM provider selection ───────────────────────────────────────────────────
# One of: ollama | claude
GM_LLM_PROVIDER=ollama

# ─── Ollama (main inference) ──────────────────────────────────────────────────
# Endpoint can be either a vanilla ollama server or a llama-line broker.
#   vanilla ollama:     http://localhost:11434
#   llama-line broker:  http://10.0.0.50:11434   (kvant)
GM_LLM_OLLAMA_ENDPOINT=http://10.0.0.50:11434
GM_LLM_OLLAMA_MODEL=qwen3:14b
GM_LLM_OLLAMA_CONTEXTTOKENBUDGET=1200
GM_LLM_OLLAMA_TIMEOUTSECONDS=300

# Bearer token. REQUIRED when ENDPOINT points at a llama-line broker.
# Leave empty when talking directly to a vanilla ollama server.
GM_LLM_OLLAMA_APIKEY=

# ─── Ollama (embeddings) ──────────────────────────────────────────────────────
# Leave EMBEDDINGENDPOINT empty to reuse GM_LLM_OLLAMA_ENDPOINT.
# Set explicitly if embeddings live on a different host (e.g. local ollama
# while inference goes through the broker).
GM_LLM_OLLAMA_EMBEDDINGENDPOINT=
GM_LLM_OLLAMA_EMBEDDINGMODEL=qwen3-embedding:0.6b

# ─── Claude (only used when GM_LLM_PROVIDER=claude) ───────────────────────────
# API key precedence (highest → lowest):
#   GM_LLM_CLAUDE_APIKEY > GM_CLAUDE_API_KEY > ANTHROPIC_API_KEY
# GM_LLM_CLAUDE_APIKEY=sk-ant-...
GM_LLM_CLAUDE_MODEL=claude-sonnet-4-6
GM_LLM_CLAUDE_CONTEXTTOKENBUDGET=8000

# ─── Server ───────────────────────────────────────────────────────────────────
GM_SERVER_PORT=8080
# Required for JWT-signed sessions. Generate with: openssl rand -hex 32
GM_SERVER_JWTSECRET=
