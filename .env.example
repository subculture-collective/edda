# Edda local development env contract.
# Copy to `.env`, adjust values, and run the app.

# Database
EDDA_DB_URL=postgres://edda:edda@localhost:5432/edda?sslmode=disable

# LLM provider: ollama, claude, or openrouter
EDDA_LLM_PROVIDER=ollama

# Ollama-compatible inference via Switchyard model broker
EDDA_LLM_OLLAMA_ENDPOINT=http://10.0.0.50:11434
EDDA_LLM_OLLAMA_MODEL=ollama/qwen3:14b
EDDA_LLM_OLLAMA_CONTEXTTOKENBUDGET=8000
EDDA_LLM_OLLAMA_TIMEOUTSECONDS=600
EDDA_LLM_OLLAMA_APIKEY=

# Ollama-compatible embeddings. Leave empty to reuse EDDA_LLM_OLLAMA_ENDPOINT.
EDDA_LLM_OLLAMA_EMBEDDINGENDPOINT=http://10.0.0.50:11434
EDDA_LLM_OLLAMA_EMBEDDINGMODEL=nomic-embed-text
EDDA_LLM_OLLAMA_EMBEDDINGDIMENSION=768

# Claude, required only when EDDA_LLM_PROVIDER=claude.
# API key precedence: EDDA_LLM_CLAUDE_APIKEY > ANTHROPIC_API_KEY
# EDDA_LLM_CLAUDE_APIKEY=sk-ant-...
EDDA_LLM_CLAUDE_MODEL=claude-sonnet-4-6
EDDA_LLM_CLAUDE_CONTEXTTOKENBUDGET=8000

# OpenRouter, required only when EDDA_LLM_PROVIDER=openrouter.
# API key precedence: EDDA_LLM_OPENROUTER_APIKEY > OPENROUTER_API_KEY
# EDDA_LLM_OPENROUTER_APIKEY=sk-or-v1-...
EDDA_LLM_OPENROUTER_MODEL=openai/gpt-4o-mini
EDDA_LLM_OPENROUTER_CONTEXTTOKENBUDGET=8000

# Optional model routing profiles. Prefer YAML config for many profiles; env
# vars are useful for quick local overrides. Routes fall back to EDDA_LLM_PROVIDER.
# EDDA_LLM_PROFILES_FAST_PROVIDER=openrouter
# EDDA_LLM_PROFILES_FAST_MODEL=mistralai/mistral-small-3.2-24b-instruct
# EDDA_LLM_PROFILES_FAST_CONTEXTTOKENBUDGET=8000
# EDDA_LLM_PROFILES_FAST_TOOLSUPPORT=true
# EDDA_LLM_ROUTES_CHOICEFALLBACK=fast
# EDDA_LLM_ROUTES_POSTTURNSTATE=fast
# EDDA_LLM_ROUTES_GMTURN=fast

# Server
EDDA_SERVER_PORT=8080
# Required for JWT-signed sessions. Generate with: openssl rand -hex 32
EDDA_SERVER_JWTSECRET=
