# Production env contract for single-host Docker deploys.
# Copy to `.env`, replace placeholders, then lock permissions with `chmod 600 .env`.
# This file intentionally overrides localhost defaults from `internal/config/config.go`.

# Release tag consumed by docker-compose.prod.yml image refs.
# Required: deploy + rollback both fail fast when this is missing.
EDDA_RELEASE_TAG=replace-with-release-tag

# Optional container-name overrides for hosts that cannot use the default names.
# Keep these in sync with the existing running app containers when overriding.
EDDA_API_CONTAINER_NAME=edda-api
EDDA_WEB_CONTAINER_NAME=edda-web

# Database (must point at the existing Postgres container on the shared Docker network)
EDDA_DB_URL=postgres://edda:replace-with-strong-db-password@pg16-pgvector:5432/edda?sslmode=disable

# Server
EDDA_SERVER_PORT=8080
EDDA_SERVER_JWTSECRET=replace-with-a-long-random-jwt-secret

# LLM provider (`ollama` or `claude`)
EDDA_LLM_PROVIDER=ollama

# Ollama mode (required when EDDA_LLM_PROVIDER=ollama)
# Locked production endpoints for this deployment model.
EDDA_LLM_OLLAMA_ENDPOINT=http://10.0.0.10:11434
EDDA_LLM_OLLAMA_MODEL=qwen3:14b
EDDA_LLM_OLLAMA_EMBEDDINGENDPOINT=http://ollama:11434
EDDA_LLM_OLLAMA_EMBEDDINGMODEL=nomic-embed-text
EDDA_LLM_OLLAMA_CONTEXTTOKENBUDGET=8000
EDDA_LLM_OLLAMA_TIMEOUTSECONDS=180

# Claude mode (required when EDDA_LLM_PROVIDER=claude)
# Preferred key variable: EDDA_LLM_CLAUDE_APIKEY.
# Supported fallback alias at runtime: ANTHROPIC_API_KEY.
EDDA_LLM_CLAUDE_APIKEY=replace-with-anthropic-api-key
EDDA_LLM_CLAUDE_MODEL=claude-sonnet-4-6
EDDA_LLM_CLAUDE_CONTEXTTOKENBUDGET=8000

# Shared Caddy container settings
CADDY_CONTAINER_NAME=replace-with-running-caddy-container-name
CADDY_SITE_CONFIG_PATH=/etc/caddy/sites/edda.subcult.tv.Caddyfile

# Cloudflare edge settings for edda.subcult.tv
CLOUDFLARE_ZONE_ID=replace-with-cloudflare-zone-id
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_RECORD_TARGET=replace-with-origin-ip-or-hostname
