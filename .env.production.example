# Edda production deploy env contract.
# Copy to a chmod 600 env file and pass it to scripts/deploy_prod.sh.

# Release image tag. Set this to the commit SHA or release tag being deployed.
EDDA_RELEASE_TAG=replace-with-release-tag

# Container and host-port overrides for this shared host.
EDDA_API_CONTAINER_NAME=gm-api
EDDA_WEB_CONTAINER_NAME=gm-web
GM_API_HOST_PORT=3036
GM_WEB_HOST_PORT=3037

# Database: must point at the existing Postgres container on the shared network.
EDDA_DB_URL=postgres://game_master:replace-with-strong-db-password@pg16-pgvector:5432/game_master?sslmode=disable

# Server
EDDA_SERVER_PORT=8080
EDDA_SERVER_JWTSECRET=replace-with-a-long-random-jwt-secret

# LLM provider: ollama or claude
EDDA_LLM_PROVIDER=ollama

# Ollama-compatible inference and embeddings via Switchyard model broker.
EDDA_LLM_OLLAMA_ENDPOINT=http://10.0.0.50:11434
EDDA_LLM_OLLAMA_MODEL=ollama/qwen3:14b
EDDA_LLM_OLLAMA_CONTEXTTOKENBUDGET=8000
EDDA_LLM_OLLAMA_TIMEOUTSECONDS=600
EDDA_LLM_OLLAMA_APIKEY=replace-with-broker-bearer-token
EDDA_LLM_OLLAMA_EMBEDDINGENDPOINT=http://10.0.0.50:11434
EDDA_LLM_OLLAMA_EMBEDDINGMODEL=nomic-embed-text
EDDA_LLM_OLLAMA_EMBEDDINGDIMENSION=768

# Claude, required only when EDDA_LLM_PROVIDER=claude.
# EDDA_LLM_CLAUDE_APIKEY=replace-with-anthropic-api-key
EDDA_LLM_CLAUDE_MODEL=claude-sonnet-4-6
EDDA_LLM_CLAUDE_CONTEXTTOKENBUDGET=8000

# Shared Caddy container
CADDY_CONTAINER_NAME=replace-with-running-caddy-container-name
CADDY_SITE_CONFIG_PATH=/etc/caddy/sites/edda.Caddyfile

# Cloudflare edge
CLOUDFLARE_ZONE_ID=replace-with-cloudflare-zone-id
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_RECORD_TARGET=replace-with-origin-ip-or-hostname
