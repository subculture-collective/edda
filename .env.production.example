# ─── Deploy plumbing (consumed by docker-compose.prod.yml + deploy scripts) ──
# Release image tag — deploy + rollback both fail fast when missing.
# Must match Docker tag charset: [A-Za-z0-9_.-]
GM_RELEASE_TAG=replace-with-release-tag

# Optional container-name overrides. Only set these if the host can't use the
# defaults. They must point at the dedicated Edda containers on the `projects`
# Docker network. Keep deploy + rollback in sync.
GM_API_CONTAINER_NAME=gm-api
GM_WEB_CONTAINER_NAME=gm-web

# ─── Database (points at the existing Postgres container on shared network) ──
GM_DB_URL=postgres://game_master:replace-with-strong-db-password@game-master-postgres:5432/game_master?sslmode=disable

# ─── Server ───────────────────────────────────────────────────────────────────
GM_SERVER_JWTSECRET=replace-with-a-long-random-jwt-secret

# ─── LLM (production-locked endpoints) ────────────────────────────────────────
# Inference goes through the kvant llama-line broker; embeddings stay on the
# in-cluster ollama container. APIKEY is required because ENDPOINT is a broker.
GM_LLM_OLLAMA_ENDPOINT=http://10.0.0.50:11434
GM_LLM_OLLAMA_APIKEY=replace-with-broker-bearer-token
GM_LLM_OLLAMA_EMBEDDINGENDPOINT=http://ollama:11434

# ─── Claude (only if GM_LLM_PROVIDER=claude in this deploy) ──────────────────
# GM_LLM_CLAUDE_APIKEY=replace-with-anthropic-api-key
